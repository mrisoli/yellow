{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "rootDirs": ["."],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@yellow/backend/*": ["../../packages/backend/*"],
      "@yellow/booking-widget": ["../../packages/booking-widget/src/index.ts"],
      "@yellow/booking-widget/*": ["../../packages/booking-widget/src/*"],
      "@yellow/ui/*": ["../../packages/ui/src/*"]
    }
  }
}
