{
  "name": "yellow",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "babel-plugin-react-compiler": "^1.0.0",
      "@types/node": "^20",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "convex": "^1.27.0",
      "radix-ui": "^1.4.3",
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "tailwindcss": "^4.1.17",
      "typescript": "^5",
      "zod": "^4.1.12"
    }
  },
  "scripts": {
    "check": "biome check --write .",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @yellow/backend dev",
    "dev:setup": "turbo -F @yellow/backend dev:setup",
    "postinstall": "turbo run build -F @yellow/ui"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "turbo": "^2.6.1",
    "ultracite": "6.3.4"
  },
  "packageManager": "bun@1.3.3"
