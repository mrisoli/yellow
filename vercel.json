{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next",
      "config": {
        "buildCommand": "cd ../.. && bun run build"
      }
    },
    {
      "src": "apps/landing-page/package.json",
      "use": "@vercel/next",
      "config": {
        "buildCommand": "cd ../.. && bun run build"
      }
    }
  ],
  "routes": [
    {
      "src": "^(?:www\\.)?app\\.(.*)$",
      "dest": "apps/web$1"
    },
    {
      "src": "/(.*)",
      "dest": "apps/landing-page/$1"
    }
  ]
}
